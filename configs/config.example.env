POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/career_copilot

# OPENAI_API_KEY=...  # embeddings (text-embedding-3-large) stored in Postgres via pgvector

# pgvector: enable on the server (Azure PostgreSQL: allowlist the extension), then
# career_copilot.database.schema.init_schema runs CREATE EXTENSION vector and creates
# jobs_embeddings + user_embeddings with HNSW indexes.

# Ranking (optional): see .env.example for MLFLOW_TRACKING_URI, MLFLOW_RANKING_RUN_ID,
# MLFLOW_EXPERIMENT_ARTIFACT_LOCATION, and Azure blob credentials for remote MLflow.
