FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /mlflow

RUN pip install --upgrade pip && \
    pip install \
        "mlflow>=3.11.1,<3.12" \
        "psycopg[binary]>=3.2.0" \
        "azure-storage-blob>=12.20.0"

EXPOSE 5000

CMD mlflow server \
    --host 0.0.0.0 \
    --port "${PORT:-5000}" \
    --backend-store-uri "${MLFLOW_BACKEND_STORE_URI:-sqlite:////mlflow/mlflow.db}" \
    --default-artifact-root "${MLFLOW_DEFAULT_ARTIFACT_ROOT:-/mlflow/artifacts}"
