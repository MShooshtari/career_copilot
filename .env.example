POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=career_copilot
# POSTGRES_PASSWORD=...  # optional; if omitted, scripts will prompt

# Azure Database for PostgreSQL (and other SSL-only servers)
# POSTGRES_SSLMODE=require

# Skip CREATE DATABASE in scripts (required for most managed Postgres, e.g. Azure)
# POSTGRES_SKIP_ENSURE_DATABASE=1

# Adzuna (optional): get free keys at https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# OpenAI (required for embeddings): job and user profile embeddings use text-embedding-3-large
# Get an API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Azure AI Search (required for RAG): job index + user-profile index (vector search, recommendations,
# resume improvement). Use an admin key for scripts/rag_index/run.py; query key is enough for read-only apps if you split keys.
# Indexes are created on first use if missing (e.g. scripts/rag_index/run.py, first profile save).
AZURE_SEARCH_ENDPOINT=https://your-service.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-admin-key
# Optional — defaults: career-copilot-jobs, career-copilot-user-profiles
# AZURE_SEARCH_INDEX_NAME=career-copilot-jobs
# AZURE_SEARCH_USER_INDEX_NAME=career-copilot-user-profiles

# MLflow (optional): if set, /recommendations will re-rank the 100 retrieved candidates
# using the model logged at runs:/${MLFLOW_RANKING_RUN_ID}/model (local tracking DB at data/mlflow.db).
MLFLOW_RANKING_RUN_ID=ab11ae9ca57448aa91881c7b5f071df8