POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=career_copilot
# POSTGRES_PASSWORD=...  # optional; if omitted, scripts will prompt

# Azure Database for PostgreSQL (and other SSL-only servers)
# POSTGRES_SSLMODE=require

# Skip CREATE DATABASE in scripts (required for most managed Postgres, e.g. Azure)
# POSTGRES_SKIP_ENSURE_DATABASE=1

# Adzuna (optional): get free keys at https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# OpenAI (required for embeddings): job and user profile vectors use text-embedding-3-large
# stored in PostgreSQL (pgvector on jobs.embedding and user_embeddings.embedding).
# Get an API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# MLflow (optional): if set, /recommendations will re-rank the 100 retrieved candidates
# using the model logged at runs:/${MLFLOW_RANKING_RUN_ID}/model (local tracking DB at data/mlflow.db).
MLFLOW_RANKING_RUN_ID=ab11ae9ca57448aa91881c7b5f071df8
