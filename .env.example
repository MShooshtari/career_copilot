POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=career_copilot
# POSTGRES_PASSWORD=...  # optional; if omitted, scripts will prompt

# Azure Database for PostgreSQL (and other SSL-only servers)
# POSTGRES_SSLMODE=require

# Skip CREATE DATABASE in scripts (required for most managed Postgres, e.g. Azure)
# POSTGRES_SKIP_ENSURE_DATABASE=1

# Adzuna (optional): get free keys at https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# OpenAI (required for embeddings): job and user profile vectors use text-embedding-3-large
# stored in PostgreSQL (pgvector in jobs_embeddings and user_embeddings).
# Get an API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------
# Authentication (Entra External ID / CIAM)
# -----------------------------
#
# Set AUTH_ENABLED=1 to require sign-in (recommended for any public deployment).
# When disabled, the app runs in local demo mode.
#
# AUTH_ENABLED=1
# SESSION_SECRET_KEY=replace-with-a-strong-random-secret
#
# OIDC client settings (from Azure portal):
# ENTRA_CLIENT_ID=your-app-client-id
# ENTRA_CLIENT_SECRET=your-app-client-secret
# ENTRA_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
#
# Recommended (most reliable): paste the OIDC discovery URL directly from the portal.
# ENTRA_METADATA_URL=https://<your-tenant>.ciamlogin.com/<tenant-guid>/v2.0/.well-known/openid-configuration
#
# If you don't set ENTRA_METADATA_URL, the app will build it from:
# ENTRA_TENANT_DOMAIN=<your-tenant>.ciamlogin.com
# ENTRA_TENANT_ID=<tenant-guid>

# MLflow (optional): if MLFLOW_RANKING_RUN_ID is set, /recommendations re-ranks candidates using
# runs:/${MLFLOW_RANKING_RUN_ID}/model.
#
# Local dev (default): leave MLFLOW_TRACKING_URI unset → sqlite:///.../data/mlflow.db + data/mlflow_artifacts/
#
# Production: set MLFLOW_TRACKING_URI to your tracking server (https://...) or database store
# (e.g. postgresql://...). For direct postgresql:// tracking URIs, also set
# MLFLOW_EXPERIMENT_ARTIFACT_LOCATION to Azure Blob (e.g. wasbs://mlflow@acct.blob.core.windows.net/artifacts).
# The API needs credentials that can read that blob container (e.g. AZURE_STORAGE_CONNECTION_STRING on Azure).
# MLFLOW_TRACKING_URI=https://your-mlflow.azurecontainerapps.io
# MLFLOW_EXPERIMENT_ARTIFACT_LOCATION=wasbs://mlflow@yourstorage.blob.core.windows.net/mlflow
MLFLOW_RANKING_RUN_ID=ab11ae9ca57448aa91881c7b5f071df8
