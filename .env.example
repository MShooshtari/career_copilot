POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=career_copilot
# POSTGRES_PASSWORD=...  # optional; if omitted, scripts will prompt

# Adzuna (optional): get free keys at https://developer.adzuna.com/signup
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key

# OpenAI (required for embeddings): job and user profile embeddings use text-embedding-3-large
# Get an API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Resume PDF rendering:
# - builtin: current simple PDF (PyMuPDF, no external tools)
# - mcp: call the local MCP LaTeX renderer (requires pdflatex / MiKTeX)
RESUME_PDF_RENDERER=mcp

# MCP subprocess for RESUME_PDF_RENDERER=mcp
# By default the app runs: python -m career_copilot.mcp_servers.resume_pdf_server
# If you need to override, set:
# CAREER_COPILOT_RESUME_MCP_COMMAND=python
# CAREER_COPILOT_RESUME_MCP_ARGS=["-m","career_copilot.mcp_servers.resume_pdf_server"]

# Resume ingestion (extract text/structure from uploaded PDF):
# - builtin: current pypdf/pymupdf plain text extraction
# - docling_mcp: use Docling MCP to convert PDF → markdown (better structure)
RESUME_PDF_INGEST=docling_mcp

# Docling MCP subprocess (for RESUME_PDF_INGEST=docling_mcp)
# Default is: python -m docling_mcp.servers.mcp_server --transport stdio
# CAREER_COPILOT_DOCLING_MCP_COMMAND=python
# CAREER_COPILOT_DOCLING_MCP_ARGS=["-m","docling_mcp.servers.mcp_server","--transport","stdio"]
